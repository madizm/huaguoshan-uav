# Environment-managed PostgREST deployment settings.
# Copy into your process manager / container secret store; do not commit real values.

# Dedicated login role created by backend/create_postgrest_authorization.sql.
# Set the database password outside source control with:
#   ALTER ROLE postgrest_authenticator PASSWORD '<secret-from-secret-manager>';
PGRST_DB_URI=postgres://postgrest_authenticator:${PGRST_DB_PASSWORD}@10.1.109.151:5432/huaguoshan_projd
PGRST_DB_SCHEMAS=citydb,public,terrain,airspace
PGRST_DB_ANON_ROLE=web_anon
PGRST_SERVER_PORT=13000

# HS256 secret shared with the auth adapter. Generate per environment, e.g.:
#   openssl rand -base64 48
PGRST_JWT_SECRET=${HGS_POSTGREST_JWT_SECRET}
